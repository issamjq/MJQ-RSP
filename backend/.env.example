# Server
PORT=4000
NODE_ENV=development

# Neon PostgreSQL
# Get this from your Neon dashboard → Connection Details → Connection string
DATABASE_URL=postgresql://username:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Playwright scraper
# Set to "false" to show browser window during development
PLAYWRIGHT_HEADLESS=true

# Timeout in ms for each page scrape (30 seconds default)
SCRAPER_TIMEOUT_MS=30000

# Max concurrent pages during a full sync run
SCRAPER_CONCURRENCY=3

# CORS — set to your React frontend URL in production
CORS_ORIGIN=http://localhost:3000
